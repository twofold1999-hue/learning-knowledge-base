{
  "name": "learning-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc",
    "test": "vitest run && node --test scripts/local-ai-proxy.test.mjs scripts/local-server-control.test.mjs scripts/local-server.test.mjs scripts/e2e-server.test.mjs",
    "test:e2e": "playwright test",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "local": "node scripts/local-server.mjs",
    "check": "npm run typecheck && npm run test && npm run build",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build --bundles nsis",
    "pretest:e2e": "npm run build",
    "e2e:server": "node scripts/e2e-server.mjs",
    "check:all": "npm run typecheck && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "d3-force": "^3.0.0",
    "dexie": "^4.4.4",
    "docx": "^9.7.1",
    "dompurify": "^3.4.12",
    "flexsearch": "^0.8.212",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "reactflow": "^11.11.4",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "~5.5.4",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24.x"
  }
}
