{
  "manifest_version": 3,
  "name": "知识库 B 站学习助手",
  "version": "0.2.0",
  "description": "在 B 站高清播放页面旁显示章节笔记，记录时间点并一键进入悬浮学习。",
  "permissions": ["sidePanel", "storage", "tabs"],
  "host_permissions": [
    "https://www.bilibili.com/*",
    "http://127.0.0.1:4173/*",
    "http://localhost:4173/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "打开知识库学习侧栏"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:4173/*", "http://localhost:4173/*"],
      "js": ["content-knowledge-base.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.bilibili.com/*"],
      "js": ["content-bilibili.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src http://127.0.0.1:4173 http://localhost:4173"
  }
}
